{
    "name": "grafana-auth-proxy-team-sync",
    "version": "1.0.0",
    "type": "module",
    "main": "src/server.js",
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/server.ts",
        "start": "node dist/server.js",
        "type-check": "tsc --noEmit",
        "biome:lint": "biome lint ./src",
        "biome:format": "biome format --write ./src",
        "biome:check": "biome check --write ./src"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "express": "^4.18.0",
        "http-proxy-middleware": "^3.0.0",
        "openid-client": "^5.6.0",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@types/express": "^5.0.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}